{
  "name": "visoky-church",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server.mjs",
    "build": "tsc && vite build && tsx scripts/prerender.mts",
    "build:ssr": "tsc && vite build --outDir dist/client && vite build --ssr src/ssr/entry-server.tsx --outDir dist/server",
    "preview": "vite preview",
    "preview:ssr": "node server.mjs --prod"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-prerender": "^1.0.8"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
